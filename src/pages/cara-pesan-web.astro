---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.vue';
import Button from '../components/Button.vue';
import { MessageCircle } from 'lucide-vue-next';
---

<Layout
    title="Form Pesan Web"
>	
	<div id="container">
		<main>	
            <PageHero title="Form Pesan Web" client:load />

            <div class="bg-sky-50 py-10">
                <div class="mx-auto max-w-[30em] min-h-0 px-6 xl:px-4 py-10 block">
                    <form action="" class="flex flex-col gap-4">
                        <p>Silahkan isi data berikut ini untuk melanjutkan chat WA</p>
                        <div>
                            <input class="w-full px-5 py-2 rounded-xl bg-white border border-slate-300" placeholder="Nama anda"/>
                        </div>
                        <div>
                            <input class="w-full px-5 py-2 rounded-xl bg-white border border-slate-300" placeholder="No WhatsApp"/>
                        </div>
                        <div>
                            <textarea rows="10" class="w-full px-5 py-2 rounded-xl bg-white border border-slate-300" placeholder="Boleh tahu, rencananya ingin membuat website untuk keperluan apa, ya?"></textarea>
                        </div>
                        <div>
                            <Button type="submit" class="w-full">
                                <div class="flex items-center gap-2 justify-center">
                                <MessageCircle class="w-5 h-5"/> WhatsApp
                                </div>
                            </Button>
                        </div>
                    </form>
                </div>
            </div>
            
        </main>	          
    </div>
</Layout>