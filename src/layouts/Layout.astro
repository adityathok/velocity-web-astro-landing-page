---
import '../styles/global.css'
import HeaderMain from '../components/HeaderMain.vue';
import FooterMain from '../components/FooterMain.vue';

// Ambil path URL saat ini (misal: /about)
const pathname = new URL(Astro.url).pathname;

//SEO props
const {
  title = 'Velocity Developer',
  description = 'Jasa Pembuatan Website, Bikin Web Murah, Profile, Toko Online, Sekolah, Berita',
  keywords = 'Jasa Pembuatan Website, Bikin Web Murah, Profile, Toko Online, Sekolah, Berita',
  image = '/default-og.jpg',
  noindex = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		 <!-- Basic SEO -->
		<title>{title} | {description}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />

		 <!-- Robots -->
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
	</head>
	<body>
	<div class="relative text-gray-800">
		<HeaderMain currentPath={pathname} client:load/>
			<slot />
		<FooterMain />
	</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
  		font-family: "Plus Jakarta Sans", sans-serif;
	}
</style>
